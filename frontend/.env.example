# ---- Meetly frontend environment ----
# Copy to ".env" (or ".env.local") for local overrides.
# CRA only exposes variables prefixed with REACT_APP_.

# Backend API + Socket.io server URL.
# Local default is http://localhost:8000 if this is unset.
# In production set this to your deployed backend, e.g.:
# REACT_APP_SERVER_URL=https://meetly-backend.onrender.com
REACT_APP_SERVER_URL=http://localhost:8000
