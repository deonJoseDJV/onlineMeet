# ---- Meetly backend environment ----
# Copy this file to ".env" and fill in your own values.

# MongoDB connection string from MongoDB Atlas (https://www.mongodb.com/atlas).
# Create a free cluster, add a database user, allow network access, then paste
# the "Connect your application" URI here.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/meetly

# Port the server listens on (Render/Heroku set this automatically).
PORT=8000

# Comma-separated allowed CORS origins. Leave unset to allow all.
# In production set this to your deployed frontend URL.
# CORS_ORIGIN=https://your-frontend.vercel.app
